    <mxCell id="title" value="なぜ LiveKit 単体ではチャットを賄えないのか" style="text;html=1;fontSize=18;fontStyle=1;align=left;" vertex="1" parent="1"><mxGeometry x="32" y="20" width="700" height="30" as="geometry" /></mxCell>
    <mxCell id="sub" value="リアルタイム配信は LiveKit のデータチャネルで既に可能。問題は「揮発的な配信しかできない」こと。" style="text;html=1;fontSize=12;fontColor=#6B7280;align=left;" vertex="1" parent="1"><mxGeometry x="32" y="48" width="820" height="20" as="geometry" /></mxCell>
    <mxCell id="lpanel" value="✗ LiveKit データチャネル単体" style="rounded=1;html=1;verticalAlign=top;align=left;spacingLeft=16;spacingTop=10;fillColor=#FDF1F1;strokeColor=#B85450;fontColor=#B85450;fontStyle=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="24" y="78" width="450" height="338" as="geometry" /></mxCell>
    <mxCell id="a" value="ブラウザA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1"><mxGeometry x="44" y="120" width="104" height="50" as="geometry" /></mxCell>
    <mxCell id="lkd" value="LiveKit data&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;（揮発・配信のみ）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;" vertex="1" parent="1"><mxGeometry x="186" y="120" width="120" height="50" as="geometry" /></mxCell>
