    <mxCell id="eb" value="" style="endArrow=classic;html=1;" edge="1" parent="1" source="lkd" target="b"><mxGeometry relative="1" as="geometry" /></mxCell>
    <mxCell id="x1" value="✗ 永続化なし（履歴・CSV エクスポート不可）" style="text;html=1;fontSize=12;fontColor=#B85450;align=left;" vertex="1" parent="1"><mxGeometry x="44" y="200" width="410" height="20" as="geometry" /></mxCell>
    <mxCell id="x2" value="✗ 後入室・リロードで過去メッセージが届かない" style="text;html=1;fontSize=12;fontColor=#B85450;align=left;" vertex="1" parent="1"><mxGeometry x="44" y="234" width="410" height="20" as="geometry" /></mxCell>
    <mxCell id="x3" value="✗ チャネル別の送信権限をサーバー強制できない&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#9B6B69&quot;&gt;（canPublishData は all-or-nothing・宛先は詐称可）&lt;/font&gt;" style="text;html=1;fontSize=12;fontColor=#B85450;align=left;" vertex="1" parent="1"><mxGeometry x="44" y="268" width="410" height="34" as="geometry" /></mxCell>
    <mxCell id="x4" value="✗ AV(LiveKit) に再結合（差し替え時に巻き込まれる）&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#9B6B69&quot;&gt;（生存期間も「ルーム接続中」に縛られる）&lt;/font&gt;" style="text;html=1;fontSize=12;fontColor=#B85450;align=left;" vertex="1" parent="1"><mxGeometry x="44" y="318" width="410" height="34" as="geometry" /></mxCell>
    <mxCell id="rpanel" value="✓ 別のリアルタイム層 ＋ DB（本書の構成）" style="rounded=1;html=1;verticalAlign=top;align=left;spacingLeft=16;spacingTop=10;fillColor=#F1F8F0;strokeColor=#82B366;fontColor=#2F855A;fontStyle=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="506" y="78" width="450" height="338" as="geometry" /></mxCell>
