<mxGraphModel dx="980" dy="540" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="980" pageHeight="540" math="0" shadow="0">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />
    <mxCell id="title" value="参考・案A：LiveKit データチャネル再利用（サーバー権威）" style="text;html=1;fontSize=18;fontStyle=1;align=left;" vertex="1" parent="1"><mxGeometry x="32" y="20" width="800" height="30" as="geometry" /></mxCell>
    <mxCell id="sub" value="送信は HTTP（Route Handler）、配信は LiveKit。追加インフラ無しだが、チャットが AV(LiveKit)に再結合する。" style="text;html=1;fontSize=12;fontColor=#6B7280;align=left;" vertex="1" parent="1"><mxGeometry x="32" y="48" width="860" height="20" as="geometry" /></mxCell>
    <mxCell id="browser" value="ブラウザ&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;role 付き JWT&lt;br&gt;送信=HTTP / 受信=DataReceived&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1"><mxGeometry x="36" y="228" width="190" height="116" as="geometry" /></mxCell>
    <mxCell id="rh" value="Next.js Route Handler&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;POST /api/chat（認可＋保存＋配信）&lt;br&gt;GET /api/chat/history（履歴）&lt;br&gt;&lt;font color=&quot;#9A7B3E&quot;&gt;宛先は listParticipants(role) で算出＝詐称不可&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;" vertex="1" parent="1"><mxGeometry x="330" y="96" width="262" height="120" as="geometry" /></mxCell>
    <mxCell id="rds" value="RDS Postgres&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;永続化・履歴・CSV&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1"><mxGeometry x="700" y="106" width="170" height="92" as="geometry" /></mxCell>
    <mxCell id="lk" value="LiveKit&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;① 映像・音声（AV）&lt;br&gt;② チャット data 配信（sendData / DataReceived）&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#B85450&quot;&gt;⚠ チャットが AV に再結合&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="330" y="320" width="262" height="118" as="geometry" /></mxCell>
    <mxCell id="e1" value="① POST 送信 / GET 履歴" style="endArrow=classic;html=1;" edge="1" parent="1" source="browser" target="rh"><mxGeometry relative="1" as="geometry" /></mxCell>
    <mxCell id="e2" value="② INSERT / SELECT(履歴)" style="endArrow=classic;startArrow=classic;html=1;strokeColor=#82B366;" edge="1" parent="1" source="rh" target="rds"><mxGeometry relative="1" as="geometry" /></mxCell>
    <mxCell id="e3" value="③ sendData（宛先＋topic）" style="endArrow=classic;html=1;" edge="1" parent="1" source="rh" target="lk"><mxGeometry relative="1" as="geometry" /></mxCell>
    <mxCell id="e4" value="④ DataReceived（受信）" style="endArrow=classic;html=1;exitX=0.25;exitY=0;entryX=1;entryY=0.7;" edge="1" parent="1" source="lk" target="browser"><mxGeometry relative="1" as="geometry" /></mxCell>
    <mxCell id="e5" value="AV（映像・音声）" style="endArrow=classic;startArrow=classic;html=1;strokeColor=#999999;exitX=0.5;exitY=1;entryX=0.1;entryY=1;" edge="1" parent="1" source="browser" target="lk"><mxGeometry relative="1" as="geometry" /></mxCell>
    <mxCell id="n1" value="認可(canSendTo)・保存・履歴 API・DB スキーマは案E／案D と共有。送信経路だけが「Route Handler → sendData」。" style="text;html=1;fontSize=12;align=left;" vertex="1" parent="1"><mxGeometry x="32" y="480" width="900" height="20" as="geometry" /></mxCell>
    <mxCell id="n2" value="追加インフラ無し（既存 LiveKit を再利用）。添付は S3(presigned, 図では省略)。受信は LiveKit ルーム接続中のみ。" style="text;html=1;fontSize=12;fontColor=#6B7280;align=left;" vertex="1" parent="1"><mxGeometry x="32" y="500" width="900" height="20" as="geometry" /></mxCell>
  </root>
</mxGraphModel>
